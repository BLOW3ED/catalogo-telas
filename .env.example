# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SOLO server-side (route handlers / server actions / script de ingesta).
# NUNCA lo expongas con prefijo NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# WhatsApp (puente al agente de ventas)
# ---------------------------------------------------------------------------
# Número en formato internacional sin '+', espacios ni guiones. Ej. México: 5214921234567
NEXT_PUBLIC_WHATSAPP_NUMBER=

# ---------------------------------------------------------------------------
# Demo
# ---------------------------------------------------------------------------
# Precios de referencia (SOLO demo). Con "true" rellena los precios vacíos con
# valores realistas por categoría y muestra la etiqueta "precio de referencia".
# Déjalo vacío o en "false" para usar únicamente los precios reales de la BD.
NEXT_PUBLIC_DEMO_PRICES=true

# ---------------------------------------------------------------------------
# Admin (/admin)
# ---------------------------------------------------------------------------
# Correos autorizados para administrar, separados por comas. SOLO servidor.
# El usuario se crea en Supabase → Authentication → Users → "Add user".
# Sin esta variable NADIE puede entrar al admin, aunque tenga cuenta.
ADMIN_EMAILS=
